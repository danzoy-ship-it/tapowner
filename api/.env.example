# TapOwner API — environment scheme
# Copy to .env for local dev. Real values NEVER committed.
# All tunable business values (prices, trial days, included traces) live in
# the app_config / products tables, NOT here — env is for infrastructure only.

# --- Core (Phase 0) ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- Database (Phase 1: Railway PostgreSQL 16 + PostGIS) ---
DATABASE_URL=postgresql://user:password@host:5432/tapowner

# --- Auth (Phase 5: email OTP + JWT sessions) ---
JWT_SECRET=change-me

# --- Email delivery for OTP codes (Phase 5). Unset -> OTP is logged, not sent
# (dev fallback, see api/src/email/console.ts). ---
RESEND_API_KEY=
OTP_FROM_ADDRESS=

# --- Billing (Phase 5: Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PROSPECTOR=
STRIPE_PRICE_CLOSER=
WEB_BASE_URL=http://localhost:3001

# --- Skip trace (Phase 6: vendor behind TraceProvider interface, swappable) ---
TRACE_PROVIDER=
TRACE_PROVIDER_API_KEY=

# --- AI drafting (Phase 7: server-side only, key never ships in the app) ---
ANTHROPIC_API_KEY=
