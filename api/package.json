{
  "name": "@tapowner/api",
  "private": true,
  "version": "0.0.1",
  "description": "Vertical-agnostic owner-contact platform core: parcels, trace provider + cache, billing, drafting, referrals, config.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "sync:crosswalk": "node scripts/sync-crosswalk.mjs",
    "test": "tsx --test src/cadattr/trueprodigy.test.ts src/lib/improvementTags.test.ts src/lib/ownerSignals.test.ts src/lib/format.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "fastify": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.2",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "resend": "^6.17.2",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
